# ==========================================================
# Split Agent environment configuration (Pharos Atlantic)
# Copy this file to ".env" and fill in your values.
# NEVER commit your real .env with the private key!
# ==========================================================

# Pharos Atlantic testnet RPC
PHAROS_RPC_URL=https://atlantic.dplabs-internal.com

# Pharos Atlantic testnet chain ID
PHAROS_CHAIN_ID=688689

# AGENT wallet private key (with or without the 0x prefix).
# This wallet deploys the contract and orchestrates the payments.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Payment mode:
#   native -> uses the Pharos NATIVE coin (PHRS). No USDC needed. (default)
#   erc20  -> uses the USDC token set in USDC_ADDRESS.
# To test with faucet PHRS, keep "native".
PAYMENT_MODE=native

# Test USDC token address on Pharos (only used in erc20 mode)
USDC_ADDRESS=0xE0BE08c77f415F577A1B3A9aD7a1Df1479564ec8

# Deployed escrow contract address (filled in after deploy)
ESCROW_ADDRESS=

# Private keys of the PAYERS (debtors), for the automatic payments.
# Format: "Name:key" pairs separated by commas. The name must match the sentence.
# Ex.: Ann:0xabc...,Pete:0xdef...
PARTICIPANT_KEYS=
